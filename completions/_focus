#compdef focus
#
# zsh completion for `focus`. Install via `focus install` (which symlinks this
# into a site-functions dir on your fpath), then `exec zsh`.

_focus() {
  local curcontext="$curcontext" state line
  local -a subs
  subs=(
    'on:start focusing (inject blocklist)'
    'off:stop focusing (remove blocklist)'
    'add:add domain(s) to the blocklist'
    'rm:remove domain(s) from the blocklist'
    'list:print the blocklist'
    'status:show enabled/disabled and domain count'
    'install:symlink onto PATH and install completion'
    'remove:uninstall focus (symlinks + clear hosts block)'
    'help:print usage'
  )

  _arguments -C \
    '1: :->cmd' \
    '*:: :->args'

  case "$state" in
    cmd)
      _describe -t commands 'focus command' subs
      ;;
    args)
      case "${line[1]}" in
        rm)
          # Resolve the blocklist the same way the focus script does: an
          # installed/managed copy (under a Homebrew Cellar or other read-only
          # prefix) keeps its list in ~/.config/focus; a checkout keeps it
          # beside the script. FOCUS_BLOCKLIST overrides both.
          local self bl
          self="${commands[focus]:A}"
          if [[ -n "$FOCUS_BLOCKLIST" ]]; then
            bl="$FOCUS_BLOCKLIST"
          elif [[ "$self" == */Cellar/* || ! -w "${self:h:h}" ]]; then
            bl="${XDG_CONFIG_HOME:-$HOME/.config}/focus/blocklist"
          else
            bl="${self:h:h}/blocklist"
          fi
          if [[ -f "$bl" ]]; then
            local -a domains
            domains=( ${(f)"$(grep -vE '^[[:space:]]*(#|$)' "$bl")"} )
            _describe -t domains 'blocked domain' domains
          fi
          ;;
      esac
      ;;
  esac
}

_focus "$@"
